generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LicensePlan {
  FREE
  PRO
  LIFETIME
}

enum NodeType {
  PHYSICAL
  VIRTUAL
  CONTAINER
  CLOUD
}

enum ServiceType {
  HTTP
  HTTPS
  TCP
  PING
  DNS
  CUSTOM
}

enum ServiceStatus {
  UP
  DOWN
  DEGRADED
  PAUSED
  UNKNOWN
}

enum LogLevel {
  DEBUG
  INFO
  WARN
  ERROR
  FATAL
}

enum AlertType {
  SERVICE_DOWN
  SERVICE_SLOW
  HIGH_ERROR_RATE
  LOG_PATTERN
  METRIC_THRESHOLD
  CUSTOM
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  passwordHash String
  settings     UserSettings?
  sessions     Session[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  theme                 String   @default("system")
  dashboardLayout       Json?
  defaultTimeRange      String   @default("24h")
  notifyOnDown          Boolean  @default(true)
  notifyOnRecover       Boolean  @default(true)
  notifyEmail           String?
  notifyWebhook         String?
  notifyDiscordWebhook  String?
  notifySlackWebhook    String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model License {
  id          String      @id @default(cuid())
  key         String      @unique
  plan        LicensePlan @default(FREE)
  activatedAt DateTime    @default(now())
  expiresAt   DateTime?
  email       String?
  isValid     Boolean     @default(true)
  metadata    Json?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model Node {
  id          String   @id @default(cuid())
  name        String
  description String?
  type        NodeType @default(PHYSICAL)
  hostname    String?
  ipAddress   String?
  os          String?
  cpu         String?
  ram         String?
  storage     String?
  tags        String[]
  isActive    Boolean  @default(true)
  services    Service[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Service {
  id             String        @id @default(cuid())
  name           String
  description    String?
  url            String?
  type           ServiceType   @default(HTTP)
  category       String?
  tags           String[]
  nodeId         String?
  node           Node?         @relation(fields: [nodeId], references: [id])
  port           Int?
  icon           String?
  color          String?
  isActive       Boolean       @default(true)
  isPinned       Boolean       @default(false)
  pingEnabled    Boolean       @default(true)
  pingInterval   Int           @default(60)
  pingTimeout    Int           @default(10)
  expectedStatus Int           @default(200)
  pingMethod     String        @default("GET")
  pingHeaders    Json?
  pingBody       String?
  currentStatus  ServiceStatus @default(UNKNOWN)
  lastCheckedAt  DateTime?
  lastUpAt       DateTime?
  lastDownAt     DateTime?
  uptimeChecks   UptimeCheck[]
  logs           LogEntry[]
  metrics        MetricSeries[]
  alerts         Alert[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model UptimeCheck {
  id           String        @id @default(cuid())
  serviceId    String
  service      Service       @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  status       ServiceStatus
  responseTime Int?
  statusCode   Int?
  error        String?
  checkedAt    DateTime      @default(now())

  @@index([serviceId, checkedAt])
  @@index([checkedAt])
}

model LogEntry {
  id        String   @id @default(cuid())
  serviceId String?
  service   Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  level     LogLevel @default(INFO)
  message   String
  source    String?
  metadata  Json?
  timestamp DateTime @default(now())

  @@index([serviceId, timestamp])
  @@index([timestamp])
  @@index([level])
}

model MetricSeries {
  id        String        @id @default(cuid())
  serviceId String?
  service   Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  name      String
  unit      String?
  points    MetricPoint[]
  createdAt DateTime      @default(now())

  @@unique([serviceId, name])
  @@index([serviceId])
}

model MetricPoint {
  id       String       @id @default(cuid())
  seriesId String
  series   MetricSeries @relation(fields: [seriesId], references: [id], onDelete: Cascade)
  value    Float
  ts       DateTime     @default(now())

  @@index([seriesId, ts])
  @@index([ts])
}

model Alert {
  id           String        @id @default(cuid())
  name         String
  serviceId    String?
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  type         AlertType
  condition    Json
  severity     AlertSeverity @default(WARNING)
  isEnabled    Boolean       @default(true)
  cooldownMins Int           @default(15)
  lastFiredAt  DateTime?
  events       AlertEvent[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model AlertEvent {
  id         String    @id @default(cuid())
  alertId    String
  alert      Alert     @relation(fields: [alertId], references: [id], onDelete: Cascade)
  message    String
  metadata   Json?
  firedAt    DateTime  @default(now())
  resolvedAt DateTime?

  @@index([alertId, firedAt])
}

model DashboardLayout {
  id        String   @id @default(cuid())
  name      String   @default("Default")
  isDefault Boolean  @default(false)
  layout    Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
